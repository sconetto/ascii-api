# ascii-api Environment Variables
# Copy this file to .env and fill in the values

# ─── File Upload Limits ───────────────────────────────────────────────────────
# Maximum upload size in bytes (default: 10MB)
MAX_FILE_SIZE=10485760

# Maximum image pixels for decompression bomb protection (default: 25MP)
MAX_PIXELS=25000000

# ─── ASCII Conversion Settings ───────────────────────────────────────────────
# Default output width in characters (min: 50, max: 200)
DEFAULT_WIDTH=100

# Maximum output width
MAX_WIDTH=200

# Default height factor for aspect ratio correction (range: 0.3-0.7)
HEIGHT_FACTOR=0.5

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Maximum requests per minute per IP
RATE_LIMIT=10

# ─── Authentication ───────────────────────────────────────────────────────────
# Enable or disable API key authentication (true/false)
AUTH_ENABLED=false

# API key for authentication (required if AUTH_ENABLED=true)
# API_KEY=your-secret-api-key-here

# ─── Logging ──────────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Output JSON format for Grafana Loki (true) or console format (false)
LOG_JSON_FORMAT=false

# Service name included in log entries
SERVICE_NAME=ascii-api

# ─── Sentry Error Tracking ───────────────────────────────────────────────────
# Sentry DSN (leave empty to disable)
# SENTRY_DSN=https://your-key@sentry.io/your-project

# Sentry environment name
SENTRY_ENVIRONMENT=development

# Sentry trace sample rate (0.0 to 1.0)
SENTRY_SAMPLE_RATE=1.0
